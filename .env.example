# AI Provider API Keys
# Copy this file to .env and fill in the key(s) for the provider(s) you want to use.
# You only need ONE free key to get started.

# Free / Fast providers
# GROQ_API_KEY="your_groq_api_key_here"
# OPENROUTER_API_KEY="your_openrouter_api_key_here"
# GOOGLE_API_KEY="your_google_api_key_here"
# CEREBRAS_API_KEY="your_cerebras_api_key_here"

# Paid / Premium providers (optional — used as manager tier if present)
# NVIDIA_API_KEY="your_nvidia_api_key_here"
# ANTHROPIC_API_KEY="your_anthropic_api_key_here"
# OPENAI_API_KEY="your_openai_api_key_here"

# Optional: increase API call timeout in seconds (default: 25)
# TRIAGEFLOW_TIMEOUT=45

# Optional local overrides (Ollama/LM Studio run locally without keys)
# OLLAMA_URL="http://localhost:11434"
# OLLAMA_MODEL="llama3.1"
# LMSTUDIO_URL="http://localhost:1234/v1"
# LMSTUDIO_MODEL="local-model"
